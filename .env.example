OPENAI_API_KEY=sk_test_...
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_GRADER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=recruiting_pipeline

PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=hiregraph

# Google OAuth — sign-in only (non-sensitive scopes, no verification needed)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gmail SMTP — sends offer letters and interview invites.
# Uses an App Password (not OAuth), so no Google verification is required and
# it can email any recipient. Enable 2-Step Verification, then create one at
# https://myaccount.google.com/apppasswords  (paste the 16 chars, no spaces)
GMAIL_ADDRESS=youremail@gmail.com
GMAIL_APP_PASSWORD=

TAVILY_API_KEY=tvly_...

FRONTEND_URL=http://localhost:3000
