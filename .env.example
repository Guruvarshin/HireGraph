OPENAI_API_KEY=sk_test_...
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_GRADER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LangSmith tracing. Get a key from the LangSmith dashboard under API Keys.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=hiregraph
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB_NAME=recruiting_pipeline

PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=hiregraph

# Google OAuth, sign-in only (non-sensitive scopes, no verification needed).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# JWT identity. After Google sign-in the server mints a signed token the frontend
# sends as a Bearer header; every route verifies it, so tenant identity can't be
# spoofed. Set a long random JWT_SECRET in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=
JWT_TTL_SECONDS=604800
# Emergency/dev only: allow the legacy spoofable X-Recruiter-ID header when no
# valid token is present. MUST stay false in production (true reopens the IDOR).
AUTH_DEV_FALLBACK=false

# Email via the Brevo HTTP API. GMAIL_ADDRESS must be a verified Brevo sender.
GMAIL_ADDRESS=youremail@gmail.com
BREVO_API_KEY=
EMAIL_SENDER_NAME=HireGraph

TAVILY_API_KEY=tvly_...

# Optional: AWS Bedrock Guardrails on resume upload (prompt-injection + PII).
# Leave BEDROCK_GUARDRAIL_ID empty to disable (falls back to summarization defense).
# Configure NAME and EMAIL to pass through so the pipeline can still contact candidates.
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Set true in production to make the guardrail mandatory and fail-closed
# (reject uploads if screening is unavailable). Leave false/unset for dev.
GUARDRAIL_REQUIRED=false

FRONTEND_URL=http://localhost:3000
